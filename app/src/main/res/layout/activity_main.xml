<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KeyMapper"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Servicio detenido"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textColor="#F44336" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- === Seccion: Modo de Inyeccion === -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[1] Metodo de inyeccion"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <RadioGroup
            android:id="@+id/rgMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">

            <RadioButton
                android:id="@+id/rbAuto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Deteccion Automatica"
                android:checked="true"
                android:padding="6dp"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/rbRoot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Root (su)"
                android:padding="6dp"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/rbShizuku"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Shizuku"
                android:padding="6dp"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/rbAdb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Depuracion Inalambrica (ADB)"
                android:padding="6dp"
                android:textSize="14sp" />
        </RadioGroup>

        <!-- Boton configurar ADB -->
        <Button
            android:id="@+id/btnConfigureAdb"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Configurar Conexion ADB..."
            android:layout_marginTop="6dp"
            android:textSize="13sp"
            android:background="#E3F2FD"
            android:textColor="#1565C0"
            android:visibility="gone" />

        <!-- Connection status -->
        <TextView
            android:id="@+id/tvAdbStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        
        <!-- === Seleccion de App Objetivo === -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[X] App Objetivo (para jugar)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSelectedApp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Todas las apps"
                android:textSize="13sp"
                android:textColor="#757575"
                android:drawablePadding="6dp"
                android:singleLine="true"
                android:ellipsize="end" />

            <Button
                android:id="@+id/btnSelectApp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Seleccionar"
                android:textSize="12sp"
                android:layout_marginStart="8dp" />

            <Button
                android:id="@+id/btnClearApp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Limpiar"
                android:textSize="12sp"
                android:layout_marginStart="4dp"
                android:background="#FFCDD2"
                android:textColor="#C62828" />
        </LinearLayout>

        <!-- === Seccion: Dispositivos === -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[2] Dispositivos Detectados"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:id="@+id/tvDevices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buscando..."
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:textColor="#757575"
            android:fontFamily="monospace" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- === Seccion: Configuracion del Raton === -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[3] Configuracion del Raton"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sensibilidad"
            android:textSize="13sp"
            android:layout_marginTop="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <SeekBar
                android:id="@+id/seekbarSensitivity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/tvSensitivityValue"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textSize="12sp"
                android:gravity="end" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/switchInvertY"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Invertir eje Y"
            android:textSize="13sp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

        <CheckBox
            android:id="@+id/switchLeftClick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Click izquierdo = Tocar"
            android:checked="true"
            android:textSize="13sp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

        <CheckBox
            android:id="@+id/switchRightClick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Click derecho = Volver"
            android:checked="true"
            android:textSize="13sp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

        <CheckBox
            android:id="@+id/switchScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scroll = Scroll pantalla"
            android:checked="true"
            android:textSize="13sp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- === Seccion: Mapeo de Teclas === -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[4] Mapeo de Teclas"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/switchKeyMapEnabled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Activo"
                android:checked="true"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnConfigureKeys"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Configurar"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvKeyMapStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Home, Back, Vol+, Vol-"
            android:textSize="11sp"
            android:textColor="#757575"
            android:layout_marginTop="2dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- === Botones Iniciar/Detener === -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="INICIAR"
                android:layout_marginEnd="8dp"
                android:background="#4CAF50"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="DETENER"
                android:layout_marginStart="8dp"
                android:background="#F44336"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- === Log === -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registro"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <ScrollView
            android:id="@+id/svLog"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="4dp"
            android:background="#E8E8E8"
            android:padding="6dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Esperando eventos..."
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:textColor="#333333" />
        </ScrollView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- === Redes Sociales === -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Desarrollado por Michael Antonio Rodriguez"
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnFacebook"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Facebook"
                android:textSize="10sp"
                android:layout_marginEnd="4dp"
                android:background="#1877F2"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnWhatsapp"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="WhatsApp"
                android:textSize="10sp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="#25D366"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnTelegram"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Telegram"
                android:textSize="10sp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="#0088CC"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnYoutube"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="YouTube"
                android:textSize="10sp"
                android:layout_marginStart="4dp"
                android:background="#FF0000"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
